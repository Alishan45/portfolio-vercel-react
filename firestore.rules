rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /reviews/{reviewId} {
      allow read: if true;    // Anyone can read reviews
      allow write: if false;  // No one can write through the client
    }
    
    match /{document=**} {
      allow read, write: if false;  // Restrict access to all other collections
    }
  }
}